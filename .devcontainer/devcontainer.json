{
  "name": "TanStack DevContainer",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "shutdownAction": "stopCompose",
  "remoteUser": "node",

  "forwardPorts": [3000, 5432],
  "portsAttributes": {
    "3000": { "label": "Application Server" },
    "5432": { "label": "Database Server" }
  },

  "postCreateCommand": "sudo chmod 666 /ssh-agent && sudo corepack enable pnpm && pnpm install",

  "mounts": [
    "source=/run/host-services/ssh-auth.sock,target=/ssh-agent,type=bind"
  ],

  "remoteEnv": {
    "SSH_AUTH_SOCK": "/ssh-agent",
    "DATABASE_URL": "postgresql://postgres:postgres@db:5432/app"
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2.5.7": {
      "installZsh": "true",
      "configureZshAsDefaultShell": "true"
    },
    "ghcr.io/rails/devcontainer/features/postgres-client:1.1.3": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "Anthropic.claude-code"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      }
    }
  }
}
